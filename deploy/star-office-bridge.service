[Unit]
Description=Star Office Bridge - Bun HTTP server for Zellij/Claude event routing
After=network.target

[Service]
Type=simple
ExecStart=/root/.bun/bin/bun run src/index.ts
WorkingDirectory=/root/free-code-star-office-zellij-lab
Environment=BRIDGE_HOST=127.0.0.1
Environment=BRIDGE_PORT=4317
Environment=BRIDGE_DRY_RUN=true
Environment=PATH=/root/.bun/bin:/usr/local/bin:/usr/bin:/bin
Restart=on-failure
RestartSec=3
StandardOutput=append:/tmp/bridge.log
StandardError=append:/tmp/bridge.log

# Security hardening
NoNewPrivileges=yes
PrivateTmp=yes
ProtectSystem=strict
ReadWritePaths=/root/free-code-star-office-zellij-lab/tmp

[Install]
WantedBy=multi-user.target
