status.karldigi.dev {
	reverse_proxy 127.0.0.1:3001
}

term.karldigi.dev {
	reverse_proxy 127.0.0.1:8082
}

bot.karldigi.dev {
	handle /v1/* {
		reverse_proxy 127.0.0.1:8642
	}
	handle /health {
		reverse_proxy 127.0.0.1:8642
	}
	handle {
		basic_auth * {
			karl $2a$14$x39R5P4qOJgvZ51OX9OCI.OKKoaZkiyEceTsFJjsuDpyZfYiJJ/TK
		}
		reverse_proxy 127.0.0.1:9119
	}
}

star.karldigi.dev {
	encode gzip
	reverse_proxy 127.0.0.1:19000

	log {
		output stderr
		format console
	}
}

bridge.karldigi.dev {
	# SSE streams: no encoding (avoid buffering delay)
	@sse path /events /events/*
	handle @sse {
		reverse_proxy 127.0.0.1:4317 {
			flush_interval -1
			stream_timeout 24h
			stream_close_delay 5m
			transport http {
				keepalive 30s
			}
		}
	}

	# Everything else: gzip + standard proxy
	handle {
		encode gzip
		reverse_proxy 127.0.0.1:4317 {
			health_uri /readyz
			health_interval 10s
			health_timeout 5s
			health_status 200
			fail_duration 30s
			max_fails 3
			unhealthy_status 5xx
			flush_interval -1
			stream_timeout 24h
			stream_close_delay 5m
			transport http {
				keepalive 30s
			}
		}
	}

	log {
		output stderr
		format console
	}
}
