# Star Office Bridge Caddy Configuration
# Reverse proxy with active + passive health checks, SSE/WebSocket support
# Install: symlink to /etc/caddy/Caddyfile or include from main Caddyfile

{
	# Global server timeouts — raised for long-lived SSE/WS connections
	servers {
		timeouts {
			read_body 10s
			read_header 10s
			write 30s
			idle 5m
		}
	}
}

# SSE + API endpoints
:4431 {
	encode gzip

	# Exclude SSE from gzip — compression delays event delivery
	@sse path /events /events/*
	encode @sse off

	reverse_proxy 127.0.0.1:4317 {
		# Active health check via /readyz
		health_uri      /readyz
		health_interval 10s
		health_timeout  5s
		health_status   200

		# Passive health checks: observe real traffic for degradation
		fail_duration    30s
		max_fails        3
		unhealthy_status 5xx

		# SSE: flush immediately (no buffering), long stream lifetime
		# WebSocket upgrade is automatic in Caddy v2
		flush_interval   -1
		stream_timeout   24h
		stream_close_delay 5m

		# Transport: keep-alive must be <= bridge's idle timeout
		transport http {
			keepalive 30s
		}
	}

	log {
		output stderr
		format console
	}
}
