(office_proxy) {
	@office path /office /office/*
	handle @office {
		uri strip_prefix /office
		reverse_proxy 127.0.0.1:19000
	}
}

star.karldigi.dev {
	import office_proxy
	handle {
		reverse_proxy 127.0.0.1:19000
	}
	log {
		output stderr
		format console
	}
}

bridge.karldigi.dev {
	@sse path /events /events/*
	handle @sse {
		reverse_proxy 127.0.0.1:4317 {
			flush_interval -1
			stream_timeout 24h
			stream_close_delay 5m
			transport http {
				keepalive 30s
			}
		}
	}

	import office_proxy

	handle {
		encode gzip
		reverse_proxy 127.0.0.1:4317 {
			health_uri /health
			health_interval 30s
			health_timeout 5s
			health_status 200
			flush_interval -1
			stream_timeout 24h
			stream_close_delay 5m
			transport http {
				keepalive 30s
			}
		}
	}

	log {
		output stderr
		format console
	}
}
